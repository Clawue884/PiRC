    <script>
        // --- Logic: Simulated CEX Price & X10 Split ---
        let baseCexPrice = 0.3140; // The target index requested by the user.

        // Simulate Oracle Drift around the index
        function updatePrices() {
            // Very minimal drift to keep simulation focused on the logic
            let drift = (Math.random() * 0.0004) - 0.0002; 
            baseCexPrice = +(baseCexPrice + drift).toFixed(4);
            
            // Update all price displays
            document.getElementById('liveCexPrice').innerText = baseCexPrice.toFixed(4);
            document.getElementById('cardCexPrice').innerText = `$${baseCexPrice.toFixed(4)}`;
            document.getElementById('bridgeCexRate').innerText = baseCexPrice.toFixed(4);
            calculate();
        }
        setInterval(updatePrices, 3000); // Transitions occur every 3 seconds

        // Justice Engine Calculator (Value Preservation Logic with X10 quantity split)
        function calculate() {
            const externalUnitAmount = parseFloat(document.getElementById('inputAmount').value);
            const internalStablePrice = parseFloat(document.getElementById('targetToken').value);
            
            // Hybrid X10 Equation:
            // ( (Amount * ExternalPrice) / InternalPrice ) * 10
            // This ensures 1 volatile unit creates 10 micro-units of the stable asset value.
            const totalUSDValue = externalUnitAmount * baseCexPrice;
            const finalInternalAmount = (totalUSDValue / internalStablePrice) * 10;
            
            // Format result with high precision (at least 8 decimal places)
            let displayAmount = finalInternalAmount < 0.000001 ? finalInternalAmount.toFixed(10) : finalInternalAmount.toFixed(8);
            
            document.getElementById('finalResult').innerText = displayAmount + " π";
        }

        // Action Feedback
        function confirmSwap() {
            const final = document.getElementById('finalResult').innerText;
            const targetName = document.getElementById('targetToken').options[document.getElementById('targetToken').selectedIndex].text;
            alert(
`[PiRC Hybrid X10 Protocol Activation]\n\n`+
`Conversion: Confirmed.\n`+
`Internal Target Asset: ${targetName}.\n\n`+
`Logic: Verified input asset against Oracle Index. \nResult: ${final} minted to internal wallet (including X10 quantity split). Stability backed by asset pools.`
            );
        }

        // Initialize first state
        updatePrices();
    </script>
