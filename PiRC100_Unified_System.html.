<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PiRC | Unified Enterprise Monetary Terminal (Hybrid Spec)</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Inter:wght@400;600;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #030303;
            --card: #0a0a0c;
            --border: #1a1a1e;
            --text-main: #ffffff;
            --text-dim: #88888e;
            /* Token Colors */
            --pi-purple: #9333ea; /* External */
            --pi-green: #10b981;  /* Retail */
            --pi-blue: #3b82f6;   /* Logistics */
            --pi-red: #ef4444;    /* Governance */
            --pi-gold: #fbbf24;   /* GCV Anchor */
            --pi-orange: #f97316; /* Liquidity */
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg); color: var(--text-main);
            margin: 0; padding: 0; overflow-x: hidden;
            font-size: 14px;
        }

        /* 📡 LIVE MARKET STATUS */
        .market-status {
            background: #000; border-bottom: 1px solid var(--border);
            padding: 12px 20px; display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 100;
        }
        .network-state { display: flex; align-items: center; gap: 8px; font-weight: 700; color: var(--pi-purple); font-size: 11px; text-transform: uppercase;}
        .dot { width: 8px; height: 8px; background: var(--pi-purple); border-radius: 50%; box-shadow: 0 0 10px var(--pi-purple); animation: pulse 2s infinite; }
        .cex-feed { font-family: 'JetBrains Mono'; font-size: 11px; color: white; }

        header { padding: 40px 20px 20px; text-align: left; background: linear-gradient(to bottom, #0a0a0c, var(--bg)); }
        header h1 { margin: 0; font-size: 22px; font-weight: 900; letter-spacing: -1px; }
        header span { color: var(--pi-purple); }

        .container { max-width: 900px; margin: auto; padding: 15px 15px 120px; }

        .section-title { font-size: 11px; text-transform: uppercase; color: var(--pi-gold); letter-spacing: 1.5px; margin: 30px 0 10px 5px; font-weight: 700; }

        /* 💎 TOKEN GRID */
        .token-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 15px; }

        .token-card {
            background: var(--card); border: 1px solid var(--border);
            border-radius: 20px; padding: 22px; transition: 0.3s;
        }
        .token-card:hover { border-color: #333; transform: translateY(-3px); }

        .token-header { display: flex; align-items: center; gap: 15px; margin-bottom: 18px; }
        .pi-logo {
            width: 45px; height: 45px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-family: serif; font-weight: 900; font-size: 24px; color: #000;
        }

        .token-name { font-weight: 700; font-size: 16px; color: white; }
        .token-price { font-family: 'JetBrains Mono'; font-size: 24px; font-weight: 700; color: white; display: block; }
        .token-spec { font-family: 'JetBrains Mono'; font-size: 10px; color: var(--pi-green); margin-top: 5px; display:block; }
        .utility-desc { font-size: 12px; color: var(--text-dim); margin-top: 10px; line-height: 1.5; }
        .stability-source { font-size: 10px; text-transform: uppercase; color: var(--pi-green); margin-top: 15px; font-weight: 700;}

        /* ⇌ INERACTIVE BRIDGE (Justice Engine Logic) */
        .bridge-section {
            background: linear-gradient(160deg, #0a0a0c 0%, #030303 100%);
            border: 1px solid var(--pi-purple); border-radius: 24px;
            padding: 25px; margin-top: 30px;
        }
        .bridge-title { font-weight: 900; font-size: 18px; margin-bottom: 20px; color: var(--pi-purple); text-align: center; }

        .bridge-ui { display: flex; flex-direction: column; gap: 15px; }
        .input-group { background: #000; padding: 18px; border-radius: 12px; border: 1px solid #222; }
        .input-group label { display: block; font-size: 10px; color: var(--text-dim); margin-bottom: 8px; text-transform: uppercase; font-weight: 700;}
        
        .input-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
        .input-group select, .input-group input {
            background: transparent; border: none; color: white; width: 100%;
            font-size: 18px; font-family: 'JetBrains Mono'; outline: none; font-weight: 700;
        }

        .swap-icon { font-size: 20px; text-align: center; color: var(--text-dim); }

        .result-box {
            background: rgba(147, 51, 234, 0.05); border: 1px dashed rgba(147, 51, 234, 0.3);
            padding: 20px; border-radius: 12px; text-align: center; margin-top: 15px;
        }
        .result-amount { font-size: 32px; font-weight: 900; color: var(--pi-gold); font-family: 'JetBrains Mono'; }
        .conversion-note { font-size: 11px; color: var(--pi-green); margin-top: 8px; font-weight: 600;}

        /* Final Action Button */
        .btn-confirm {
            background: var(--pi-purple); color: white; border: none;
            width: calc(100% - 30px); padding: 20px; border-radius: 16px;
            font-weight: 800; font-size: 16px; text-transform: uppercase;
            cursor: pointer; box-shadow: 0 10px 30px rgba(147, 51, 234, 0.3);
            position: fixed; bottom: 20px; left: 15px; max-width: 470px; z-index: 90;
        }
        .btn-confirm:active { transform: scale(0.98); opacity: 0.9; }

        footer { text-align: center; color: #333; font-size: 10px; padding: 20px 0; line-height: 1.6; }

        @media (min-width: 768px) {
            .bridge-ui { flex-direction: row; align-items: center; }
            .bridge-ui > * { flex: 1; }
            .swap-icon { transform: rotate(90deg); }
        }

        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }
    </style>
</head>
