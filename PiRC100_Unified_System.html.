    <script>
        // Simulate Price Fluctuations
        function updatePrices() {
            // Internal Price (Base: 0.314159)
            const internalBase = 0.314159;
            const inDrift = (Math.random() * 0.0002) - 0.0001;
            const finalInternal = (internalBase + inDrift).toFixed(6);
            document.getElementById('priceInVal').innerText = finalInternal;

            // Exchange Price (Base: 3.141592)
            const exchangeBase = 3.141592;
            const exDrift = (Math.random() * 0.01) - 0.005; // More speculative drift
            const finalExchange = (exchangeBase + exDrift).toFixed(6);
            document.getElementById('priceExVal').innerText = finalExchange;
        }
        setInterval(updatePrices, 2500);

        // Regenerate Hash (PiRC-45 Logic)
        function updateHash() {
            const chars = 'abcdef0123456789';
            let newHash = '';
            for (let i = 0; i < 64; i++) {
                newHash += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            document.getElementById('liveHash').innerText = newHash;
        }
        setInterval(updateHash, 4000);

        // Interaction Feedback
        function initializeTransaction() {
            const btn = document.querySelector('.btn-primary');
            btn.innerText = "VERIFYING CONVERSION...";
            btn.style.background = "white";
            btn.style.color = "black";
            
            setTimeout(() => {
                const exPrice = document.getElementById('priceExVal').innerText;
                const inPrice = document.getElementById('priceInVal').innerText;
                btn.innerText = "SYNCHRONIZED ✔";
                btn.style.background = "var(--success)";
                btn.style.color = "white";
                
                alert(`PiRC-100 Justice Engine Activated.\n\n`+
                      `Current Exchange Rate: $${exPrice}/M (Speculative)\n`+
                      `Current Internal Rate: $${inPrice} (Utility-First)\n\n`+
                      `Weighted Split (WCF): Verifying 10,000,000 unit pool against active engagement.`);
            }, 1800);
        }

